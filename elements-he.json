    "xpath": "//div[span/text() = \"מחיר\"]/input",
    "type": "input",
    "defaults": []
  },
  "post_sku": {
    "xpath": "//div[span/text() = \"SKU\"]/input",
    "type": "input",
    "defaults": []
  },
  "post_location": {
    "xpath": "//div[span/text() = \"מיקום\"]/input",
